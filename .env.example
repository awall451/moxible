# Moxible Phase 1.5 environment knobs.
#
# Copy to `web/.env` (or paste these into `web/docker-compose.yml`'s
# `environment:` block) and edit. Once the first-run wizard ships in
# Phase 2+, these vars become unnecessary — the wizard collects the same
# information through the browser and writes /data/config.yml instead.
#
# This file contains NO secrets. The container generates its own SSH key
# in /data/keys/ on first start; you never paste private keys here.

# --- container surface ---
PORT=4080
# ALLOWED_ORIGINS=http://localhost:4080

# --- proxmox connection ---
# PVE_HOST=192.0.2.10
# PVE_USER=root
# PVE_BASTION=
# SSH_KEY_PATH=/data/keys/id_ed25519_pve
# DEFAULT_PUBKEY_PATH=/data/keys/id_ed25519_pve.pub

# --- guest defaults ---
# CLOUD_USER=admin
# DOTFILES_URL=

# --- network ---
# SUBNET_PREFIX=192.0.2
# NETWORK_GATEWAY=192.0.2.1
# CIDR_PREFIX=24
# DNS_SERVERS=1.1.1.1 8.8.8.8
# NETWORK_BRIDGE=vmbr0

# --- storage ---
# VM_STORAGE=local-lvm
# SNIPPETS_STORAGE=local

# --- template ---
# TEMPLATE_VMID=9000

# --- VMID range used by the auto-scan + UI picker ---
# VMID_RANGE_START=200
# VMID_RANGE_END=254

# --- protection (comma-separated VMIDs that destroy-vm.yml refuses) ---
# CRITICAL_VMIDS=
